  "author": "Luca Trifilio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luca-trifilio/tree-sitter-bru.git"
  },
  "bugs": {
    "url": "https://github.com/luca-trifilio/tree-sitter-bru/issues"
  },
  "homepage": "https://github.com/luca-trifilio/tree-sitter-bru#readme",
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.6"
  },
  "scripts": {
    "build": "tree-sitter generate",
